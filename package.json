{
  "name": "optishield",
  "version": "0.1.0",
  "private": true,
  "description": "Optical Privacy for the Modern Web - a privacy-first browser extension that reduces optical capture readability.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --config vite.config.ts",
    "build": "tsc --noEmit && node scripts/build-extension.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "verify:extension": "node scripts/verify-extension.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.10",
    "typescript": "^5.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.468.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.8.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "@eslint/js": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "esbuild": "^0.21.5"
  }
}
