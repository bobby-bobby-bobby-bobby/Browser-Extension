{
  "manifest_version": 3,
  "name": "OptiShield",
  "description": "Privacy-first optical capture resistance for normal browsing.",
  "version": "0.1.0",
  "action": {
    "default_title": "OptiShield",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  }
}
