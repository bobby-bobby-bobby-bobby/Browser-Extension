{
  "manifest_version": 3,
  "name": "OptiShield",
  "description": "Optical Privacy for the Modern Web",
  "version": "0.1.0",
  "action": {
    "default_title": "OptiShield",
    "default_popup": "src/popup/index.html"
  },
  "options_page": "src/settings/index.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [],
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  }
}
